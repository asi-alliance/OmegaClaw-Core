# Oma / OmegaClaw local runtime configuration

# Local Ollama endpoint and default runtime model.
OLLAMA_BASE_URL=http://192.168.86.22:11434
OLLAMA_MODEL=granite4:32b-a9b-h

# Channel authentication secret. Leave empty only for trusted local testing.
OMEGACLAW_AUTH_SECRET=

# Persona prompt file, relative to memory/ unless absolute.
OMEGACLAW_PROMPT_FILE=prompt-esther.txt

# Structured CRO / ethics risk register storage.
OMEGACLAW_RISK_REGISTER=/home/omaclaw/PeTTa/repos/OmegaClaw-Core/memory/risks.jsonl

# Context continuity budgets. The WebUI model switcher also injects
# provider/model-specific maxHistory/maxFeedback values to protect local models
# from raw history floods while preserving a deterministic continuity snapshot.
OMEGACLAW_CONTEXT_SNAPSHOT=enabled

# Optional remote provider keys. Never commit real values.
OPENAI_MODEL=gpt-5.5
OPENAI_DISPLAY_NAME=ChatGPT 5.5
OPENAI_REASONING_EFFORT=medium
OPENAI_BASE_URL=
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-6
ANTHROPIC_VERSION=2023-06-01
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-pro
DEEPSEEK_DISPLAY_NAME=DeepSeek V4 Pro
DEEPSEEK_THINKING=disabled
DEEPSEEK_REASONING_EFFORT=high
OPENAI_API_KEY=
ASI_API_KEY=
